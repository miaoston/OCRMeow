{
  "manifest_version": 3,
  "name": "OCRMeow",
  "version": "0.1.0",
  "description": "3D Liquid Glassmorphism OCR Chrome Extension based on PaddleOCR.js",
  "permissions": ["activeTab", "storage", "offscreen", "scripting", "contextMenus", "downloads"],
  "background": {
    "service_worker": "src/background/worker.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Click to start OCR selection",
    "default_icon": {
      "16": "public/icon-16.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "options_page": "dashboard.html",
  "content_scripts": [
    {
      "js": ["src/content/index.ts"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self';"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["models/*", "wasm/*", "sandbox.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
